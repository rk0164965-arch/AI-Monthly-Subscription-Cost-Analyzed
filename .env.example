# Ollama Cloud API Key (get from ollama.com account settings)
OLLAMA_API_KEY=your_api_key_here

# Mode: "cloud" or "local"
OLLAMA_MODE=cloud

# Cloud model (use -cloud suffix)
OLLAMA_MODEL=qwen3:4b-cloud

# Cloud API base URL
OLLAMA_CLOUD_URL=https://ollama.com

# Local Ollama URL (only used when OLLAMA_MODE=local)
OLLAMA_URL=http://localhost:11434

# Server port
PORT=3001
